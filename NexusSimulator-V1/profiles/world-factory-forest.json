  "defaultWorldStructure": "bounded",
  "worldStructures": {
    "infinite": {
      "label": "Infinite World",
      "dimensions": 3,
      "coordinateModel": "origin-rebased-continuous",
      "parameters": { "streamingRadius": 6, "originRebasing": true },
      "guide": { "kind": "grid", "size": 18, "color": "#72c7e8" },
      "requirements": [
        { "path": "dimensions", "operator": "equals", "value": 3, "label": "Three spatial dimensions are declared" },
        { "path": "parameters.streamingRadius", "operator": "min", "value": 1, "label": "Streaming radius is positive" },
        { "path": "parameters.originRebasing", "operator": "equals", "value": true, "label": "Origin rebasing is enabled" }
      ]
    },
    "patched": {
      "label": "Patched World",
      "dimensions": 3,
      "coordinateModel": "stitched-patches",
      "parameters": { "patchSize": 28, "activePatchRadius": 2, "seamStitching": true },
      "guide": { "kind": "patch-grid", "size": 12, "color": "#68d391" },
      "requirements": [
        { "path": "parameters.patchSize", "operator": "min", "value": 1, "label": "Patch size is positive" },
        { "path": "parameters.activePatchRadius", "operator": "min", "value": 1, "label": "Active patch radius is positive" },
        { "path": "parameters.seamStitching", "operator": "equals", "value": true, "label": "Patch seams are stitched" }
      ]
    },
    "bounded": {
      "label": "Bounded World",
      "dimensions": 3,
      "coordinateModel": "cartesian-bounds",
      "parameters": { "bounds": { "x": 28, "y": 12, "z": 20 }, "boundaryCollision": true },
      "guide": { "kind": "box", "size": 8, "color": "#f1b85b" },
      "requirements": [
        { "path": "parameters.bounds.x", "operator": "min", "value": 1, "label": "World width is positive" },
        { "path": "parameters.bounds.y", "operator": "min", "value": 1, "label": "World height is positive" },
        { "path": "parameters.bounds.z", "operator": "min", "value": 1, "label": "World depth is positive" },
        { "path": "parameters.boundaryCollision", "operator": "equals", "value": true, "label": "Boundary collision is enabled" }
      ]
    },
    "spherical": {
      "label": "Spherical World",
      "dimensions": 3,
      "coordinateModel": "radial-surface",
      "parameters": { "radius": 14, "closedSurface": true, "gravityMode": "radial" },
      "guide": { "kind": "sphere", "size": 4.6, "color": "#72c7e8" },
      "requirements": [
        { "path": "parameters.radius", "operator": "min", "value": 1, "label": "Sphere radius is positive" },
        { "path": "parameters.closedSurface", "operator": "equals", "value": true, "label": "World surface is closed" },
        { "path": "parameters.gravityMode", "operator": "matches", "value": "^radial$", "label": "Gravity follows the radial frame" }
      ]
    },
    "full-spatial": {
      "label": "Full Spatial World",
      "dimensions": 3,
      "coordinateModel": "free-3d-volume",
      "parameters": { "freePlacement": true, "spatialIndex": "octree", "gravityMode": "configurable" },
      "guide": { "kind": "axes", "size": 5.5, "color": "#d9ef77" },
      "requirements": [
        { "path": "dimensions", "operator": "equals", "value": 3, "label": "Full XYZ space is enabled" },
        { "path": "parameters.freePlacement", "operator": "equals", "value": true, "label": "Free three-dimensional placement is enabled" },
        { "path": "parameters.spatialIndex", "operator": "matches", "value": "^(octree|bvh|grid-3d)$", "label": "A supported spatial index is configured" }
      ]
    },
    "toroidal": {
      "label": "Toroidal World",
      "dimensions": 3,
      "coordinateModel": "wrapped-volume",
      "parameters": { "wrapAxes": "xz", "majorRadius": 12, "minorRadius": 4 },
      "guide": { "kind": "torus", "size": 4.8, "color": "#d996ff" },
      "requirements": [
        { "path": "parameters.wrapAxes", "operator": "matches", "value": "^(x|z|xz|xyz)$", "label": "At least one world axis wraps" },
        { "path": "parameters.majorRadius", "operator": "min", "value": 1, "label": "Major radius is positive" },
        { "path": "parameters.minorRadius", "operator": "min", "value": 0.1, "label": "Minor radius is positive" }
      ]
    },
    "layered": {
      "label": "Layered World",
      "dimensions": 3,
      "coordinateModel": "stacked-spaces",
      "parameters": { "layers": 4, "portalRouting": true, "layerSpacing": 6 },
      "guide": { "kind": "layers", "size": 5, "color": "#ff9b79" },
      "requirements": [
        { "path": "parameters.layers", "operator": "min", "value": 2, "label": "At least two spatial layers exist" },
        { "path": "parameters.portalRouting", "operator": "equals", "value": true, "label": "Cross-layer routing is enabled" },
        { "path": "parameters.layerSpacing", "operator": "min", "value": 0.1, "label": "Layer spacing is positive" }
      ]
    }
  },
